# Local remote-services mode:
# - Use Neon pooled URL for DATABASE_URL
# - Use Neon direct/unpooled URL for DIRECT_URL
# - Use localhost Google OAuth redirect/origin
# - S3 bucket CORS must allow http://localhost:3000
DATABASE_URL="postgresql://<db-user>:<db-password>@<db-pooled-host>/<db-name>?channel_binding=require&sslmode=require"
DIRECT_URL="postgresql://<db-user>:<db-password>@<db-direct-host>/<db-name>?channel_binding=require&sslmode=require"
NEXTAUTH_SECRET="<random-64-char-hex>"
NEXTAUTH_URL="http://localhost:3000"
GOOGLE_CLIENT_ID="<google-client-id>"
GOOGLE_CLIENT_SECRET="<google-client-secret>"
S3_REGION="<s3-region>"
S3_ENDPOINT="https://<s3-endpoint>"
S3_BUCKET="<s3-bucket>"
S3_ACCESS_KEY_ID="<s3-access-key-id>"
S3_SECRET_ACCESS_KEY="<s3-secret-access-key>"
S3_PUBLIC_BASE_URL="https://<s3-public-base-url>"
DEFAULT_STORAGE_LIMIT_BYTES="53687091200"
DEFAULT_RETENTION_DAYS="30"
ZIP_TTL_HOURS="2"
CLEANUP_CRON_SECRET="<random-64-char-hex>"
ADMIN_EMAILS="<comma-separated-admin-emails>"
WORKER_POLL_INTERVAL_MS="5000"
